# ============================================================================
# ARCHFORGE — ENVIRONMENT CONFIGURATION
# ============================================================================
# Copy this file to .env and fill in your values:
#   cp .env.example .env
# ============================================================================

# ── LLM Layer 0: Groq (Primary — Ultra-Fast) ──
# Get your API key from: https://console.groq.com/keys
# Model used: llama-3.1-70b-versatile (fastest inference)
GROQ_API_KEY=gsk-your-groq-api-key-here
# GROQ_MODEL=llama-3.1-70b-versatile    # Optional: override model

# ── LLM Layer 1: OpenAI (Fallback 1) ──
# Get your API key from: https://platform.openai.com/api-keys
# Model used: gpt-4o-mini (lower rate limits than gpt-4o)
OPENAI_API_KEY=sk-your-openai-api-key-here

# ── LLM Layer 2: Google Gemini (Fallback) ──
# Get your API key from: https://aistudio.google.com/apikey
# Model used: gemini-2.0-flash (fast, free tier available)
GEMINI_API_KEY=your-gemini-api-key-here
# GEMINI_MODEL=gemini-2.0-flash          # Optional: override model

# ── LLM Layer 3: Ollama (Local Fallback) ──
# Install Ollama: https://ollama.com/download
# Then run: ollama pull qwen2.5-coder
# OLLAMA_HOST=localhost                    # Optional: default localhost
# OLLAMA_PORT=11434                        # Optional: default 11434
# OLLAMA_MODEL=qwen2.5-coder              # Optional: default qwen2.5-coder

# ── Server ──
# PORT=3000                                # Optional: default 3000
